# NextAuth v5
AUTH_SECRET=                        # openssl rand -base64 32

# Kakao OAuth — developers.kakao.com
AUTH_KAKAO_ID=                      # REST API 키
AUTH_KAKAO_SECRET=                  # Client Secret (보안 > 활성화 필요)
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/kakao

# Naver OAuth — developers.naver.com
AUTH_NAVER_ID=                      # 애플리케이션 Client ID
AUTH_NAVER_SECRET=                  # Client Secret
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/naver
# ※ 네이버는 검수 전 등록한 이메일만 로그인 가능 (개발자 계정 제외)

# Google OAuth — console.cloud.google.com
AUTH_GOOGLE_ID=                     # OAuth 2.0 클라이언트 ID
AUTH_GOOGLE_SECRET=                 # 클라이언트 보안 비밀번호
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/google

# Supabase — supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=           # https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # anon / public key
SUPABASE_SERVICE_ROLE_KEY=          # service_role key (서버 전용, 클라이언트 노출 금지)

# App URL (Vercel 배포 후 실제 URL로 교체)
NEXTAUTH_URL=http://localhost:3000

# Admin basic auth for /admin + /api/cells mutations
ADMIN_USER=admin
ADMIN_PASS=                         # strong password — rotate for production
